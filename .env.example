# Copy to .env and fill in. .env is gitignored; this file is committed.
#
# Two main configurations are supported:
#   1. Offline: leave OPENAI_API_KEY and PINECONE_API_KEY blank, set
#      VECTOR_STORE=faiss. Everything works against the local FAISS index
#      with the deterministic template explainer.
#   2. Production demo: fill in the Azure + Pinecone blocks below and set
#      VECTOR_STORE=pinecone. The pipeline uses Azure OpenAI embeddings,
#      Pinecone retrieval, and the GPT explainer.

# --- Azure OpenAI (embeddings + chat) ---
# Hits Azure's OpenAI-compatible v1 endpoint. The model fields are Azure
# *deployment names*, not OpenAI model IDs.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://<your-resource>.cognitiveservices.azure.com/openai/v1/
OPENAI_EMBEDDING_MODEL=<your-text-embedding-3-large-deployment-name>
OPENAI_EMBEDDING_DIMENSION=3072
OPENAI_CHAT_MODEL=<your-chat-deployment-name>

# --- Pinecone (vector store + reranker) ---
PINECONE_API_KEY=
PINECONE_INDEX_NAME=medical-rag-medquad
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
# bge-reranker-v2-m3 is free on every Pinecone project; cohere-rerank-3.5
# is stronger but requires Cohere access. The wrapper auto-falls-back on 403.
PINECONE_RERANK_MODEL=bge-reranker-v2-m3

# --- Pipeline selectors ---
VECTOR_STORE=faiss
